// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enum para Roles de Usuario en COTAL
enum Role {
  USER
  HOST
  ADMIN
}

enum ServiceStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentMethod {
  CASH
  QR
  CARD
}

// Modelo de Usuario
model User {
  id        String   @id @default(uuid())
  nombre    String
  apellido  String
  email     String   @unique
  password  String
  rol       Role     @default(USER)

  services  Service[]
  requests  ServiceRequest[]
  conversations Conversation[]

  // Relaciones de calificaciones
  reviewsGiven    Review[] @relation("UserReviews")
  reviewsReceived Review[] @relation("HostReviews")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Service {
  id          String        @id @default(uuid())

  title       String
  description String

  price       Float
  category    String

  status      ServiceStatus @default(PENDING)

  ownerId     String
  owner       User          @relation(fields: [ownerId], references: [id])
  requests    ServiceRequest[]
  reviews     Review[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

enum RequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model ServiceRequest {
  id           String        @id @default(uuid())
  serviceId    String
  service      Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  message      String
  contactPhone String
  desiredDate  DateTime
  status       RequestStatus @default(PENDING)
  paymentMethod PaymentMethod @default(CASH)

  review       Review?
  conversation  Conversation?

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("service_requests")
}

model Conversation {
  id         String         @id @default(uuid())

  requestId  String         @unique
  request    ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  // Participants (denormalized for quick access)
  userId     String
  user       User           @relation(fields: [userId], references: [id])

  messages   Message[]

  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderId       String
  senderRole     Role

  body           String
  readAt         DateTime?

  createdAt      DateTime     @default(now())

  @@map("messages")
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  comment   String?

  userId    String
  user      User     @relation("UserReviews", fields: [userId], references: [id])

  hostId    String
  host      User     @relation("HostReviews", fields: [hostId], references: [id])

  serviceId String
  service   Service  @relation(fields: [serviceId], references: [id])

  requestId String         @unique
  request   ServiceRequest @relation(fields: [requestId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reviews")
}